# Server Configuration
PORT=3001
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-to-a-random-string
SESSION_MAX_AGE=86400000

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8574
CHROMA_DATABASE=knolege_sfit

# SQLite Database Path
DB_PATH=./data/knolege.db

# Default LLM (for direct chat without KB)
DEFAULT_LLM_BASE_URL=http://localhost:8000/v1
DEFAULT_LLM_API_KEY=your-api-key
DEFAULT_LLM_MODEL=gpt-3.5-turbo

# Default System Prompt
DEFAULT_SYSTEM_PROMPT=你是知识库问答助手。请基于提供的文档内容回答用户问题。如果提供的信息不足以回答问题，请明确说明。

# LLM Timeout (ms)
LLM_TIMEOUT=300000
