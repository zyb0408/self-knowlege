# Server Configuration
PORT=3001
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-to-a-random-string
SESSION_MAX_AGE=86400000

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8574
CHROMA_DATABASE=knolege_sfit

# SQLite Database Path
DB_PATH=./data/knolege.db

# Default LLM config (shared across all knowledge bases)
DEFAULT_LLM_BASE_URL=http://localhost:8000/v1
DEFAULT_LLM_API_KEY=your-api-key
DEFAULT_LLM_MODEL=unsloth/Qwen3.6-35B-A3B

# Default Embedding config (shared across all knowledge bases)
DEFAULT_EMBEDDING_BASE_URL=http://localhost:8000/v1
DEFAULT_EMBEDDING_API_KEY=your-api-key
DEFAULT_EMBEDDING_MODEL=text-embedding-ada-002

# Default System Prompt
DEFAULT_SYSTEM_PROMPT=你是知识库问答助手。请基于提供的文档内容回答用户问题。如果提供的信息不足以回答问题，请明确说明。

# LLM Timeout (ms)
LLM_TIMEOUT=300000
