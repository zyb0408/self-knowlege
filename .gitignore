dist/
build/
coverage/
target/
.DS_Store
Thumbs.db

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.PyCharmCache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```